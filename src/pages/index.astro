---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
import AboutUs from "../components/About.astro";
import PopularPacks from "../components/PopularPacks.astro"
import GiftsGallery from '../components/GiftsGallery.astro';
import CTAsection from '../components/CTAsection.astro';
import Testimonials from '../components/Testimonials.astro';
import GiftCTA from '../components/GiftCTA.astro';
import Footer from '../components/Footer.astro';

---

<Layout>
  <div class="bg-[#02A4B3]">
    <div class="aspect-[16/9] max-h-[600px] w-full overflow-hidden">
      <img src="/images/banner-image.jpg" class="h-full w-full object-cover" />
    </div>
  </div>


  <AboutUs />
  <PopularPacks />
  <CTAsection />
  <GiftsGallery />
  <Testimonials />
  <GiftCTA />
  <Footer />
</Layout>
