---
import '../styles/tailwind.css';

---


<!doctype html>
<html lang="en" class="bg-gray-50 text-gray-900">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Astro Basics</title>
	</head>
	<body>
    <header class="sticky top-0 z-50 bg-[#E8F6F8] shadow-md">
      <nav class="container mx-auto px-5 relative">
        <div class="flex h-16 items-center justify-between">

            <!-- Logo -->
            <a href="/" class="flex h-full items-center">
                <img
                    src="/images/gifterra-logo.svg"
                    class="h-10 md:h-12"
                    alt="Gifterra logo"
                />
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden items-center gap-8 md:flex">

                <a href="/" class="text-[#02A4B3] hover:text-[#015961] transition">
                    About
                </a>

                <a href="/about" class="text-[#02A4B3] hover:text-[#015961] transition">
                    Featured Packs
                </a>

                <a href="/gallery" class="text-[#02A4B3] hover:text-[#015961] transition">
                    Gallery
                </a>

                <a href="/testimonials" class="text-[#02A4B3] hover:text-[#015961] transition">
                    Testimonials
                </a>

            </div>

            <!-- Mobile Menu Button -->
            <button
                id="menu-btn"
                class="flex h-10 w-10 items-center justify-center rounded md:hidden"
                aria-label="Open Menu"
            >
                ☰
            </button>

        </div>

        <!-- Mobile Menu -->
        <div
            id="mobile-menu"
            class="absolute left-0 top-full z-50 hidden w-full rounded-b-xl bg-white shadow-lg md:hidden"
        >

            <a
                href="/"
                class="block border-b px-5 py-4 text-[#02A4B3] hover:bg-cyan-50"
            >
                About
            </a>

            <a
                href="/about"
                class="block border-b px-5 py-4 text-[#02A4B3] hover:bg-cyan-50"
            >
                Featured Packs
            </a>

            <a
                href="/gallery"
                class="block border-b px-5 py-4 text-[#02A4B3] hover:bg-cyan-50"
            >
                Gallery
            </a>

            <a
                href="/testimonials"
                class="block px-5 py-4 text-[#02A4B3] hover:bg-cyan-50"
            >
                Testimonials
            </a>
        </div>
      </nav>
    </header>
    
    <script>
      const menuBtn = document.getElementById("menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");

      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener("click", () => {
          mobileMenu.classList.toggle("hidden");

          menuBtn.textContent = mobileMenu.classList.contains("hidden")
            ? "☰"
            : "✕";
        });
      }
    </script>

    

    <main class="mx-auto">
      <slot />
    </main>
	</body>
</html>
