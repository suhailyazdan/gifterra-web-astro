---

import astroLogo from '../assets/astro.svg';
import { Icon } from "astro-icon/components";

---



<footer class="bg-[#2f2f2f] text-white">
  <div class="container mx-auto px-6 py-16">

    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">

      <!-- Logo & Social -->
      <div>

        <a href="/">
          <img
            src="/images/gifterra-logo.svg"
            alt="Gifterra Logo"
            class="w-44"
          />
        </a>

        <p class="mt-6 text-lg leading-8 text-cyan-400">
          Curating happiness,<br />
          one box at a time.
        </p>

        <!-- Social Icons -->
        <div class="mt-8 flex gap-4">

          <a
            href="https://facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="group flex h-11 w-11 items-center justify-center rounded-full bg-fuchsia-500 transition-all duration-300 hover:-translate-y-1 hover:bg-cyan-500"
          >
            <Icon
              name="simple-icons:facebook"
              class="h-5 w-5 text-white transition-transform duration-300 group-hover:scale-110"
            />
          </a>

          <a
            href="https://linkedin.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="group flex h-11 w-11 items-center justify-center rounded-full bg-fuchsia-500 transition-all duration-300 hover:-translate-y-1 hover:bg-cyan-500"
          >
            <Icon
              name="simple-icons:linkedin"
              class="h-5 w-5 text-white transition-transform duration-300 group-hover:scale-110"
            />
          </a>

          <a
            href="https://instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="group flex h-11 w-11 items-center justify-center rounded-full bg-fuchsia-500 transition-all duration-300 hover:-translate-y-1 hover:bg-cyan-500"
          >
            <Icon
              name="simple-icons:instagram"
              class="h-5 w-5 text-white transition-transform duration-300 group-hover:scale-110"
            />
          </a>

          <a
            href="https://pinterest.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Pinterest"
            class="group flex h-11 w-11 items-center justify-center rounded-full bg-fuchsia-500 transition-all duration-300 hover:-translate-y-1 hover:bg-cyan-500"
          >
            <Icon
              name="simple-icons:pinterest"
              class="h-5 w-5 text-white transition-transform duration-300 group-hover:scale-110"
            />
          </a>

        </div>

      </div>

      <!-- Quick Links -->
      <div>

        <h3 class="mb-6 text-xl font-semibold text-cyan-400">
          Quick Links
        </h3>

        <ul class="space-y-3">

          <li>
            <a href="/about" class="transition hover:pl-2 hover:text-cyan-300">
              About Us
            </a>
          </li>

          <li>
            <a href="/collections" class="transition hover:pl-2 hover:text-cyan-300">
              Collections
            </a>
          </li>

          <li>
            <a href="/corporate-gifting" class="transition hover:pl-2 hover:text-cyan-300">
              Corporate Gifting
            </a>
          </li>

          <li>
            <a href="/faq" class="transition hover:pl-2 hover:text-cyan-300">
              FAQs
            </a>
          </li>

        </ul>

      </div>

      <!-- Legal -->
      <div>

        <h3 class="mb-6 text-xl font-semibold text-cyan-400">
          Legal
        </h3>

        <ul class="space-y-3">

          <li>
            <a href="/privacy-policy" class="transition hover:pl-2 hover:text-cyan-300">
              Privacy Policy
            </a>
          </li>

          <li>
            <a href="/terms-and-conditions" class="transition hover:pl-2 hover:text-cyan-300">
              Terms & Conditions
            </a>
          </li>

          <li>
            <a href="/shipping-policy" class="transition hover:pl-2 hover:text-cyan-300">
              Shipping Policy
            </a>
          </li>

          <li>
            <a href="/sitemap" class="transition hover:pl-2 hover:text-cyan-300">
              Sitemap
            </a>
          </li>

        </ul>

      </div>

      <!-- Newsletter -->
      <div>

        <h3 class="mb-6 text-xl font-semibold text-cyan-400">
          Newsletter
        </h3>

        <p class="mb-6 text-gray-300">
          Get updates on new collections and special offers.
        </p>

        <form class="flex overflow-hidden rounded-xl bg-white">

          <input
            type="email"
            placeholder="Enter your email"
            class="w-full px-4 py-3 text-gray-700 outline-none"
          />

          <button
            type="submit"
            class="flex items-center justify-center bg-cyan-500 px-5 transition hover:bg-cyan-600"
          >
            <span class="text-2xl font-bold text-white">➜</span>
          </button>

        </form>

      </div>

    </div>

  </div>

  <!-- Copyright -->
  <div class="border-t border-gray-700 py-6 text-center bg-[#1f1f1f]">
    <p class="text-gray-300">
      © 2026 Gifterra. All Rights Reserved.
    </p>
  </div>

</footer>