  <section class="bg-[#E8F6F8] py-12 md:py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-5 text-[#018692]">

    <!-- Heading -->
    <div class="mx-auto mb-12 max-w-3xl text-center">
      <h1 class="mb-4 text-3xl font-semibold md:text-4xl">
        Our Popular Gift Packs
      </h1>

      <h3 class="text-lg md:text-xl">
        Handpicked collections loved by our customers. Find the perfect gift
        for your special someone.
      </h3>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">

      <!-- Card 1 -->
      <div class="overflow-hidden rounded-2xl bg-white shadow transition duration-300 hover:-translate-y-2 hover:shadow-xl">

        <div class="h-64 overflow-hidden md:h-72">
          <img
            src="/images/other-images/Slice 2.jpg"
            alt="Gift Pack"
            class="h-full w-full object-cover transition duration-500 hover:scale-110"
          />
        </div>

        <div class="p-6 md:p-8">

          <h2 class="text-xl font-semibold">
            A Relaxation Box
          </h2>

          <p class="mt-2 text-base md:text-lg">
            A curated set of spa essentials for a blissful escape.
          </p>

          <div class="mt-8 flex items-center justify-between">

            <h3 class="text-2xl font-semibold md:text-3xl">
              Rs. 90
            </h3>

            <button
              class="rounded-full bg-[#02A4B3] px-5 py-2 text-white transition hover:bg-[#0B7786]"
            >
              View Details
            </button>

          </div>

        </div>

      </div>

      <!-- Card 2 -->
      <div class="overflow-hidden rounded-2xl bg-white shadow transition duration-300 hover:-translate-y-2 hover:shadow-xl">

        <div class="h-64 overflow-hidden md:h-72">
          <img
            src="/images/other-images/Slice 3.jpg"
            alt="Gift Pack"
            class="h-full w-full object-cover transition duration-500 hover:scale-110"
          />
        </div>

        <div class="p-6 md:p-8">

          <h2 class="text-xl font-semibold">
            A Relaxation Box
          </h2>

          <p class="mt-2 text-base md:text-lg">
            A curated set of spa essentials for a blissful escape.
          </p>

          <div class="mt-8 flex items-center justify-between">

            <h3 class="text-2xl font-semibold md:text-3xl">
              Rs. 90
            </h3>

            <button
              class="rounded-full bg-[#02A4B3] px-5 py-2 text-white transition hover:bg-[#0B7786]"
            >
              View Details
            </button>

          </div>

        </div>

      </div>

      <!-- Card 3 -->
      <div class="overflow-hidden rounded-2xl bg-white shadow transition duration-300 hover:-translate-y-2 hover:shadow-xl">

        <div class="h-64 overflow-hidden md:h-72">
          <img
            src="/images/other-images/Slice 4.jpg"
            alt="Gift Pack"
            class="h-full w-full object-cover transition duration-500 hover:scale-110"
          />
        </div>

        <div class="p-6 md:p-8">

          <h2 class="text-xl font-semibold">
            A Relaxation Box
          </h2>

          <p class="mt-2 text-base md:text-lg">
            A curated set of spa essentials for a blissful escape.
          </p>

          <div class="mt-8 flex items-center justify-between">

            <h3 class="text-2xl font-semibold md:text-3xl">
              Rs. 90
            </h3>

            <button
              class="rounded-full bg-[#02A4B3] px-5 py-2 text-white transition hover:bg-[#0B7786]"
            >
              View Details
            </button>

          </div>

        </div>

      </div>

    </div>

  </div>
</section>
