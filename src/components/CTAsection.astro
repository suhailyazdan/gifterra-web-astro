<section class="border-b border-cyan-600 bg-[#fff0e0] py-12 md:py-16 lg:py-20 text-[#018692]">
  <div class="mx-auto max-w-7xl px-5">

    <div class="grid items-center gap-10 lg:grid-cols-5 lg:gap-20">

      <!-- Image -->
      <div class="order-1 lg:order-1 lg:col-span-2 overflow-hidden rounded-2xl bg-blue-100 shadow-md">
        <img
          src="/images/other-images/about.jpg"
          alt="Customized Gift"
          class="h-72 w-full object-cover md:h-96 lg:h-auto"
        />
      </div>

      <!-- Content -->
      <div class="order-2 lg:order-2 lg:col-span-3">

        <h2
          class="mb-5 text-center text-3xl font-semibold leading-tight md:text-4xl lg:text-right"
        >
          Make your Gift as Unique as Emotions
        </h2>

        <p
          class="mb-6 text-center text-lg font-semibold leading-relaxed lg:text-right"
        >
          Add your favorite items, choose wrapping styles, and write heartfelt
          messages—all in one place. Make every celebration unforgettable with
          gifts that truly speak from your heart.
        </p>

        <p
          class="mb-8 text-center text-base leading-relaxed md:text-lg lg:text-right"
        >
          At Gifterra, we believe that a great gift is more than just an item—
          it's an experience. We specialize in curating and customizing
          beautiful gift packs filled with high-quality, thoughtful products.
          Our mission is to make gifting a joyful and seamless experience for
          everyone.
        </p>

        <div class="flex justify-center lg:justify-end">
          <button
            class="rounded-full bg-[#02A4B3] px-7 py-3 font-semibold text-white shadow transition-all duration-300 hover:-translate-y-1 hover:bg-[#0B7786] hover:shadow-lg"
          >
            Read More...
          </button>
        </div>

      </div>

    </div>

  </div>
</section>
