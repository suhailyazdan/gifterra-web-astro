  <section class="bg-[#D1EEF1] py-12 md:py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-5">

    <!-- Heading -->
    <div class="mx-auto mb-12 max-w-4xl text-center">

      <h2 class="mb-4 text-3xl font-semibold text-[#018692] md:text-4xl">
        Gifts Gallery
      </h2>

      <p class="text-lg text-[#018692] md:text-xl">
        Explore our curated collection of beautifully packaged gifts, perfect
        for every occasion. Each gift pack is thoughtfully designed to impress
        and ready to delight your loved ones.
      </p>

    </div>

    <!-- ================= MOBILE ================= -->

    <div class="grid grid-cols-2 gap-4 md:hidden">

      {images.map((image, index) => (
        <div class="overflow-hidden rounded-xl">
          <img
            src={image}
            alt={`Gift ${index + 1}`}
            class="aspect-square w-full object-cover transition duration-500 hover:scale-110"
          />
        </div>
      ))}

    </div>

    <!-- ================= TABLET ================= -->

    <div class="hidden grid-cols-3 gap-5 md:grid lg:hidden">

      {images.map((image, index) => (
        <div class="overflow-hidden rounded-xl">
          <img
            src={image}
            alt={`Gift ${index + 1}`}
            class="aspect-square w-full object-cover transition duration-500 hover:scale-110"
          />
        </div>
      ))}

    </div>

    <!-- ================= DESKTOP ================= -->

    <div class="hidden lg:block">

      <div class="grid aspect-[16/9] grid-cols-12 grid-rows-12 gap-5">

        <div class="col-span-3 row-span-12 overflow-hidden rounded-2xl">
          <img src={images[0]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

        <div class="col-span-3 row-span-6 overflow-hidden rounded-2xl">
          <img src={images[1]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

        <div class="col-span-3 row-span-6 overflow-hidden rounded-2xl">
          <img src={images[2]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

        <div class="col-span-3 row-span-3 overflow-hidden rounded-2xl">
          <img src={images[3]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

        <div class="col-span-3 row-span-3 overflow-hidden rounded-2xl">
          <img src={images[4]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

        <div class="col-span-2 row-span-6 overflow-hidden rounded-2xl">
          <img src={images[5]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

        <div class="col-span-4 row-span-6 overflow-hidden rounded-2xl">
          <img src={images[6]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

        <div class="col-span-3 row-span-3 overflow-hidden rounded-2xl">
          <img src={images[7]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

        <div class="col-span-3 row-span-3 overflow-hidden rounded-2xl">
          <img src={images[8]} class="h-full w-full object-cover transition duration-500 hover:scale-110" />
        </div>

      </div>

    </div>

  </div>
</section>
