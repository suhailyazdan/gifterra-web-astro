---

<section class="bg-[#e9e9e9] py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-10">

      <!-- Left Section -->
      <div class="flex-1 max-w-xl text-center md:text-left">
        <h2 class="text-3xl md:text-4xl font-bold text-[#1aa3b0] leading-tight mb-5">
          Have a special request or a corporate inquiry?
        </h2>

        <p class="text-[#1aa3b0]/90 text-base md:text-lg leading-relaxed mb-8 max-w-md mx-auto md:mx-0">
          We'd love to help you create the perfect gift. Get in touch with our gifting specialists today.
        </p>

        <button
          class="bg-white text-[#1aa3b0] font-semibold px-7 py-3.5 rounded-full shadow-sm
                 hover:bg-[#1aa3b0] hover:text-white transition-colors duration-300 cursor-pointer"
        >
          Contact Us Now
        </button>
      </div>

      <!-- Right Section -->
      <div class="flex-1 flex justify-center md:justify-end">
        <img
          src="/images/gift-pack.png"
          alt="Gift box with candles"
          class="w-full max-w-md md:max-w-lg object-contain drop-shadow-xl"
        />
      </div>

    </div>
  </div>
</section>